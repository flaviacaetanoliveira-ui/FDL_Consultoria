# Copie para secrets.toml (não versionar secrets reais) ou configure no painel do Streamlit Cloud
# (Settings → Secrets). Em cloud, use sempre variáveis neste ficheiro TOML.

# --- Pasta partilhada OneDrive/SharePoint (sincroniza dataset completo ; URL com :f:/) ---
# FDL_APP_MODE = "client"
# FDL_DATA_SOURCE = "onedrive"
# FDL_ONEDRIVE_URL = "https://...sharepoint.com/:f:/g/personal/..."
# Pasta dentro do link onde estão cursor/cliente_1 (ajuste aos nomes reais):
# FDL_ONEDRIVE_ROOT_FOLDER = "cursor"
# FDL_ONEDRIVE_CLIENT_FOLDER = "cliente_1"
# Na Streamlit Cloud, partilhas SharePoint costumam precisar de token (Bearer) Microsoft Graph:
# FDL_MS_GRAPH_TOKEN = "eyJ0eXA..."

# --- Produção cliente (mais simples na Cloud): tabela pré-gerada (.csv/.xlsx) ---
# Rode no PC/agendador: powerbi_mirror/export_powerbi_dataset.py → conciliacao_operacional.csv
# Suba o ficheiro ao OneDrive/SharePoint e use link de PARTILHA DO FICHEIRO (abre o .csv/.xlsx),
# não o link de pasta com :f:/ no URL — esse caminho sincroniza ZIP e é pesado.
# FDL_APP_MODE = "client"
# Erros ao carregar dados: true (omisso) mostra traceback na página; false = mensagem genérica ao cliente.
# FDL_SHOW_LOAD_ERRORS = false
# FDL_DATA_SOURCE = "precomputed"
# FDL_PRECOMPUTED_URL = "https://suaempresa.sharepoint.com/.../conciliacao_operacional.csv"
# Também aceita short links 1drv.ms (a app converte para download).
# Link SharePoint longo (ex. :x:/ Excel) na Cloud: se falhar, acrescente FDL_MS_GRAPH_TOKEN com
# bearer Microsoft Graph (app registration; permissões de leitura de ficheiros conforme o tenant).
#
# Desenvolvimento local com o mesmo modo (sem secrets):
#   set FDL_DATA_SOURCE=precomputed
#   set FDL_PRECOMPUTED_PATH=powerbi_mirror\output\conciliacao_operacional.csv

# opcional: caminho absoluto no servidor (raro em cloud)
# FDL_PRECOMPUTED_PATH = "/mount/.../conciliacao_operacional.csv"

# --- Modo completo: pipeline OneDrive (pasta partilhada ou ZIP/CSV no link) ---
# FDL_DATA_SOURCE = "onedrive"
# FDL_ONEDRIVE_URL = "..."   # .zip, .csv no link, ou pasta :f:/

# FDL_BASE_DIR = "/path/to/cliente_1"
