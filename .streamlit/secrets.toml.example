# Copie para secrets.toml (não versionar secrets reais) ou configure no painel do Streamlit Cloud
# (Settings → Secrets). Em cloud, use sempre variáveis neste ficheiro TOML.

# --- Pasta partilhada OneDrive/SharePoint (sincroniza dataset completo ; URL com :f:/) ---
# FDL_APP_MODE = "client"
# FDL_DATA_SOURCE = "onedrive"
# FDL_ONEDRIVE_URL = "https://...sharepoint.com/:f:/g/personal/..."
# Pasta dentro do link onde estão cursor/cliente_1 (ajuste aos nomes reais):
# FDL_ONEDRIVE_ROOT_FOLDER = "cursor"
# FDL_ONEDRIVE_CLIENT_FOLDER = "cliente_1"
# Na Streamlit Cloud, partilhas SharePoint costumam precisar de token (Bearer) Microsoft Graph:
# FDL_MS_GRAPH_TOKEN = "eyJ0eXA..."

# --- Produção cliente (mais simples na Cloud): tabela pré-gerada (.csv/.xlsx) ---
# Rode no PC/agendador: powerbi_mirror/export_powerbi_dataset.py → conciliacao_operacional.csv
# Suba o ficheiro ao OneDrive/SharePoint e use link de PARTILHA DO FICHEIRO (abre o .csv/.xlsx),
# não o link de pasta com :f:/ no URL — esse caminho sincroniza ZIP e é pesado.
# FDL_APP_MODE = "client"
# Erros ao carregar dados: true (omisso) mostra traceback na página; false = mensagem genérica ao cliente.
# FDL_SHOW_LOAD_ERRORS = false
# FDL_DATA_SOURCE = "precomputed"
# FDL_PRECOMPUTED_URL = "https://suaempresa.sharepoint.com/.../conciliacao_operacional.csv"
# Também aceita short links 1drv.ms (a app converte para download).
# Link SharePoint longo (ex. :x:/ Excel) na Cloud: se falhar, acrescente FDL_MS_GRAPH_TOKEN com
# bearer Microsoft Graph (app registration; permissões de leitura de ficheiros conforme o tenant).
#
# Desenvolvimento local com o mesmo modo (sem secrets):
#   set FDL_DATA_SOURCE=precomputed
#   set FDL_PRECOMPUTED_PATH=powerbi_mirror\output\conciliacao_operacional.csv

# opcional: caminho absoluto no servidor (raro em cloud)
# FDL_PRECOMPUTED_PATH = "/mount/.../conciliacao_operacional.csv"

# --- Modo completo: pipeline OneDrive (pasta partilhada ou ZIP/CSV no link) ---
# FDL_DATA_SOURCE = "onedrive"
# FDL_ONEDRIVE_URL = "..."   # .zip, .csv no link, ou pasta :f:/

# --- Base local (OneDrive do cliente): Repasse + Frete leem a mesma pasta ---
# Recomendado: caminho absoluto para cliente_1 real (ex.: Cursor/Anto Moveis), para nao cair no cliente_1 de exemplo dentro do repo V2.
# FDL_BASE_DIR = "C:/Users/<user>/OneDrive - FDL Consultoria/Cursor/Anto Moveis/cliente_1"
# Alternativa: junction de ./cliente_1 no repo para essa pasta, ou omitir FDL_BASE_DIR se so existir a copia real em ./cliente_1.
#
# Repasse ficheiro no mesmo cliente_1 (opcional, modo precomputed local):
# FDL_DATA_SOURCE = "precomputed"
# FDL_PRECOMPUTED_PATH = "cliente_1/precomputed/conciliacao_operacional.csv"
#
# Frete na Cloud: FDL_FRETE_VENDAS_URL = "https://...export_ml.xlsx"

# --- Checklist: Frete “igual ao Repasse” (ler tabela final, sem fluxo live) ---
# 1) Gere o espelho do frete no PC (agendador): `python processing/materialize_financeiro.py --base-dir ... --modulo frete`
#    → deve existir `.../data_products/<cliente>/<empresa>/frete/current/dataset_frete_app.csv`.

# 2) Repasse materializado (já usa tabela final): defina por exemplo
#    FDL_REPASSE_CONSUME_MODE = "materialized"
#    FDL_REPASSE_MATERIALIZED_PATH = "data_products/.../repasse/current/dataset_repasse_app.csv"
#    (ou FDL_REPASSE_MATERIALIZED_URL com link direto ao ficheiro).

# 3) Frete materializado — opção A (explícito): aponte o CSV do frete
#    FDL_FRETE_CONSUME_MODE = "materialized"
#    FDL_FRETE_MATERIALIZED_PATH = "data_products/.../frete/current/dataset_frete_app.csv"
#    (ou FDL_FRETE_MATERIALIZED_URL em vez do PATH).

#    Opção B (mesmo “review” que o repasse): com o CSV do repasse em `.../repasse/current/...` (via
#    FDL_REPASSE_MATERIALIZED_PATH **ou** FDL_PRECOMPUTED_PATH) e `dataset_frete_app.csv` em `.../frete/current/`,
#    a app resolve o frete ao lado (inclui quem só usa precomputed para o repasse, sem FDL_REPASSE_*).

# Sem 2+3 e sem vendas ML na pasta/URL, o painel de Frete cai no modo compatibilidade e pede FDL_FRETE_VENDAS_URL.

# --- Documentação ---
# Ver docs/frete_producao_materializado.md (rotina agendada, validação, Cloud).
